# Production build config (loaded by `vite build`, i.e. on Vercel).
#
# These are NOT secrets — the host and database name are public and already
# visible in the shipped client bundle. Committing them means a Vercel build
# is correctly pointed at maincloud with no dashboard configuration.
#
# To point production at a different backend, override these in the Vercel
# project's Environment Variables (dashboard values win over this file).
VITE_SPACETIMEDB_HOST=wss://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DB_NAME=spacecards

# Google sign-in. This OAuth client ID is public (it ships in the bundle and is
# the audience the server validates against — see spacetimedb/src/constants.ts).
# Keep it in sync with that server constant.
VITE_GOOGLE_CLIENT_ID=171597117898-udk35oal7pgj04a08uldr0k7cpa2tuaa.apps.googleusercontent.com
