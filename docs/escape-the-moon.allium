-- allium: 3
-- escape-the-moon.allium
--
-- Escape the Moon — the first real GAME built on the generic verb engine
-- (engine.allium). Crash-land on the moon with a printer and almost nothing;
-- scavenge, refine, fabricate, automate with drones, build a rocket, escape.
-- Distilled from spacetimedb/src/content/ and the game-specific parts of
-- spacetimedb/src/engine/resolvers.ts. Source of intent: docs/ESCAPE_THE_MOON.md.
--
-- Relationship to the engine: this spec is the CONTENT that plugs into the
-- engine's machinery. It does not restate the verb lifecycle, readiness, output
-- caps, housing, identity or the surfaces — those are engine.allium. It declares:
--   - the catalogue (which CardDefs exist, what their holes accept)
--   - the resolver behaviour per verb (what each consumes/produces — the
--     fulfilment of the engine's VerbResolver contract)
--   - the recipe DATA (builds, subsystems, research tree, the Wreck manifest)
--   - the two gates (Power, Blueprints), the worker-bay automation ladder
--   - the opening deal and the achievement arc
--
-- The engine's Card / CardDef / SlotDef / Situation / Board are referenced here as
-- external entities (governed by engine.allium). This file is kept independently
-- checkable — it does not `use`-import the engine — so the seam is documented in
-- prose and the @FulfilsVerbResolver guarantee rather than a hard cross-file link.

------------------------------------------------------------
-- External Entities (governed by engine.allium)
------------------------------------------------------------

-- The engine's catalogue template. The game AUTHORS instances of these (see the
-- Catalogue defaults below) but their lifecycle and fields belong to the engine.
external entity CardDef {
    def_id: String
    category: String
    is_verb: Boolean
    drone_level: Integer
}

-- A live card instance on a board.
external entity Card {
    def: CardDef
    board: Board
}

-- A board's lifetime card-history tally: how many of each def_id have EVER been
-- created on this board (the same count that drives achievements and gates
-- Research). "History is the state" — there is no separate counter. Read-only,
-- maintained by the engine on every card birth.
external entity CardHistory {
    board: Board
    def: CardDef
    count: Integer
}

external entity Board {
    cards: Card with board = this
    histories: CardHistory with board = this
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

-- A Workbench build recipe: a Blueprint card's def_id selects exactly one output
-- (no fragile count-matching). `cost` Components are consumed. `keep` blueprints
-- are handed back (drones + the Solar Array — you want a whole fleet/farm from one
-- manual); others are one-and-done.
value Build {
    blueprint: CardDef          -- the selector card
    output: CardDef             -- the machine/drone produced (dormant in the tray)
    cost: Integer               -- Components consumed
    keep: Boolean               -- blueprint returned rather than consumed?
}

-- An Assembler subsystem recipe: a category->count requirement plus one Power.
-- Checked most-specific-first so an overlapping load resolves deterministically.
value Recipe {
    output: CardDef
    needs: Set<Requirement>
}

value Requirement {
    category: String
    count: Integer
}

-- A Research-tree entry. A blueprint is EARNED here (one Effort -> the next one you
-- qualify for). `needs` are CATEGORY counts read off lifetime history; `requires`
-- are prerequisite blueprints that must already be discovered (the drone Mk ladder).
value ResearchEntry {
    target: CardDef             -- the blueprint earned
    needs: Set<Requirement>     -- ≥1 (or ≥3) of each category, summed over history
    prerequisites: Set<CardDef> -- blueprints that must already be discovered
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

-- The escalating energy currencies — the §3 "currency ladder". Each gates a tier
-- of machine and is more precious than the last.
enum Currency { effort | power | fuel }

-- The drone automation ladder. A bay demands a minimum Mk (a pure access gate);
-- Effort is the universal worker that fits every bay.
enum WorkerLevel { effort | mk_1 | mk_2 | mk_3 | mk_4 }

------------------------------------------------------------
-- Config — durations (game-balance timing; durations.ts)
------------------------------------------------------------

-- Kept short so the whole gather->refine->fabricate->assemble->launch chain is
-- observable live within a minute or two. The chemistry branch (CHEM) is the
-- deliberate late bottleneck; the drone heartbeat is the fastest clock so a drone
-- keeps its machine fed faster than the machine consumes.
config {
    drone_tick: Duration = 2.seconds        -- a bay drone feeds one card per tick
    effort_cycle: Duration = 6.seconds      -- the Survivor emitting one Effort
    solar_cycle: Duration = 5.seconds       -- the Solar Array emitting one Power
    gather: Duration = 4.seconds            -- one raw (Field / Wreck) per Effort
    print: Duration = 6.seconds             -- the crude Printer: raw -> Component
    build: Duration = 6.seconds             -- the Workbench assembling from a blueprint
    research: Duration = 8.seconds          -- the bench earning the next blueprint
    refine: Duration = 5.seconds            -- raw -> Metal
    fabricate: Duration = 6.seconds         -- Metal -> Component
    kiln: Duration = 6.seconds              -- raw -> Silicon / Glass
    electronics: Duration = 7.seconds       -- Silicon -> Circuit
    mine_ice: Duration = 6.seconds          -- Power -> Water
    electrolysis: Duration = 7.seconds      -- Water -> Hydrogen + Oxygen
    chem: Duration = 10.seconds             -- H2 + O2 -> Fuel (the bottleneck)
    assemble: Duration = 12.seconds         -- ingredients -> a rocket Subsystem
    launch: Duration = 15.seconds           -- the Rocket counting down to Escape
}

------------------------------------------------------------
-- Defaults — the catalogue (authored in content/catalogue.ts)
------------------------------------------------------------
-- Categories matter: a hole accepts by category or def_id. Note the deliberate
-- overlaps — Scrap and Regolith are both `raw`; Salvage is a `component` (a
-- ready-made part from the wreck); Effort is a `drone` (the universal worker).

-- ── Inert resources ──────────────────────────────────────
default CardDef effort   = { def_id: "effort",   category: "drone",     is_verb: false, drone_level: 99 }  -- the universal worker
default CardDef power     = { def_id: "power",     category: "power",     is_verb: false, drone_level: 0 }   -- the gate token
default CardDef regolith  = { def_id: "regolith",  category: "raw",       is_verb: false, drone_level: 0 }
default CardDef scrap      = { def_id: "scrap",     category: "raw",       is_verb: false, drone_level: 0 }
default CardDef salvage    = { def_id: "salvage",   category: "component", is_verb: false, drone_level: 0 }  -- ready-made part
default CardDef metal       = { def_id: "metal",     category: "metal",     is_verb: false, drone_level: 0 }
default CardDef silicon     = { def_id: "silicon",   category: "silicon",   is_verb: false, drone_level: 0 }
default CardDef glass        = { def_id: "glass",     category: "glass",     is_verb: false, drone_level: 0 }
default CardDef circuit      = { def_id: "circuit",   category: "circuit",   is_verb: false, drone_level: 0 }
default CardDef component     = { def_id: "component", category: "component", is_verb: false, drone_level: 0 }  -- the universal part
default CardDef water         = { def_id: "water",     category: "water",     is_verb: false, drone_level: 0 }
default CardDef hydrogen      = { def_id: "hydrogen",  category: "hydrogen",  is_verb: false, drone_level: 0 }
default CardDef oxygen        = { def_id: "oxygen",    category: "oxygen",    is_verb: false, drone_level: 0 }
default CardDef fuel          = { def_id: "fuel",      category: "fuel",      is_verb: false, drone_level: 0 }

-- Rocket subsystems (inert; Assembler outputs, Rocket inputs).
default CardDef engine_sub    = { def_id: "engine",       category: "subsystem", is_verb: false, drone_level: 0 }
default CardDef hull           = { def_id: "hull",         category: "subsystem", is_verb: false, drone_level: 0 }
default CardDef avionics        = { def_id: "avionics",     category: "subsystem", is_verb: false, drone_level: 0 }
default CardDef life_support     = { def_id: "life_support", category: "subsystem", is_verb: false, drone_level: 0 }
default CardDef heat_shield       = { def_id: "heat_shield",  category: "subsystem", is_verb: false, drone_level: 0 }

default CardDef escape            = { def_id: "escape",          category: "endgame",   is_verb: false, drone_level: 0 }  -- the win token
default CardDef warehouse         = { def_id: "warehouse",       category: "warehouse", is_verb: false, drone_level: 0 }  -- buildable container
default CardDef exhausted_wreck    = { def_id: "exhausted_wreck", category: "debris",    is_verb: false, drone_level: 0 }  -- picked-clean husk

