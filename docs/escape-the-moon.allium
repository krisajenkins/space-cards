default CardDef bp_electronics_fab    = { def_id: "blueprint_electronics_fab", category: "blueprint", is_verb: false, drone_level: 0 }
default CardDef bp_ice_mine            = { def_id: "blueprint_ice_mine",        category: "blueprint", is_verb: false, drone_level: 0 }
default CardDef bp_electrolysis         = { def_id: "blueprint_electrolysis",    category: "blueprint", is_verb: false, drone_level: 0 }
default CardDef bp_chem_reactor          = { def_id: "blueprint_chem_reactor",    category: "blueprint", is_verb: false, drone_level: 0 }
default CardDef bp_assembler              = { def_id: "blueprint_assembler",       category: "blueprint", is_verb: false, drone_level: 0 }
