default CardDef bp_refinery        = { def_id: "blueprint_refinery",        category: "blueprint", is_verb: false, drone_level: 0 }
default CardDef bp_fabricator       = { def_id: "blueprint_fabricator",       category: "blueprint", is_verb: false, drone_level: 0 }
